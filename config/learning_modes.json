      "liveTradingEnabled": false,
      "maxMarkets": 2,
      "maxFamilies": 10,
      "allowedFamilies": [
        "breakout",
        "pullback",
        "momentum",
        "mean_reversion",
        "volatility_expansion",
        "opening_range"
      ],
      "promotionGuard": {
        "minTrades": 40,
        "minExpectancy": 0,
        "maxDrawdownPct": 25,
        "minProfitFactor": 1.05,
        "maxTopTradesPnlShare": 0.65,
        "requireWalkForwardPass": true,
        "targetEnvironment": "paper"
      }
    },
    "expand_6m": {
