# Copy to .env and adjust. Do not commit real .env (secrets).
# Near-live / freshness (aligns with ops/launchd/run-nearlive.sh + com.neuropilot.nearlive.plist)

NEUROPILOT_DATA_ROOT=/Volumes/TradingDrive/NeuroPilotAI

# Bounded critical gate + partial degrade (Yahoo equities not listed — soft / manifest only)
NEUROPILOT_CRITICAL_DATASETS=BTCUSDT_5m,BTCUSDT_1h,ETHUSDT_5m,ETHUSDT_1h,SOLUSDT_5m,SOLUSDT_1h,BNBUSDT_5m,BNBUSDT_1h,ADAUSDT_5m,ADAUSDT_1h,XRPUSDT_5m,XRPUSDT_1h,XAUUSD_5m,XAUUSD_1h
NEUROPILOT_PARTIAL_DEGRADE_ON_STALE=1

# Yahoo equities: visibility only (stale → softMonitorStaleDatasets / run_health, no hard-fail)
NEUROPILOT_SOFT_MONITOR_DATASETS=AAPL_5m,AAPL_1h,IWM_5m,IWM_1h,NVDA_5m,NVDA_1h,QQQ_5m,QQQ_1h,SPY_5m,SPY_1h,TSLA_5m,TSLA_1h

# Paper quality metrics (buildPaperQualityMetrics.js → governance/paper_quality_metrics.json + ops-snapshot/paper_quality_summary.json)
# NEUROPILOT_PAPER_QUALITY_SYMBOLS=ADAUSDT,XRPUSDT
# NEUROPILOT_PAPER_QUALITY_STRATEGIES=ORB_breakout_v1,EMA_pullback_v2
NEUROPILOT_WAVE1_SYMBOLS=BTCUSDT,ETHUSDT,XRPUSDT,ADAUSDT
# NEUROPILOT_WAVE1_FORCE_SIGNALS=1
# Paper signals from generated_strategies/setup_mut_*.json (not meta_ranking):
# NEUROPILOT_WAVE1_FORCE_SIGNALS_FROM_GENERATED=1
# NEUROPILOT_WAVE1_GENERATED_MAX_SETUPS=80
# NEUROPILOT_PAPER_QUALITY_ROLLING_DAYS=7
# (same N for rolling exitTs and rolling simulatedAt)
# NEUROPILOT_PAPER_QUALITY_SINCE_PATCH_AT=2026-03-24T00:00:00.000Z
# governance/paper_quality_actions.json (audit only; never blocks execution)
# NEUROPILOT_PAPER_QUALITY_SUGGEST_MIN_TRADES=4
# NEUROPILOT_PAPER_QUALITY_DEPRIORITIZE_MIN_TRADES=10
# NEUROPILOT_PAPER_QUALITY_DEPRIORITIZE_STRATEGIES=EMA_pullback_v2

# Autonomous entry engine (paper) — symbol universe + gating
# DATA_DIR defaults to ./data; place active_symbol_universe.json there (or set ACTIVE_SYMBOL_UNIVERSE_PATH).
# ENABLE_AUTONOMOUS_ENTRY_ENGINE=true
# AUTO_ENTRY_USE_UNIVERSE_FILE=true
# ACTIVE_SYMBOL_UNIVERSE_PATH=
# Fallback when no universe file / empty activeSymbols (OANDA-mapped symbols only unless you extend oandaPriceAdapter):
# AUTO_ENTRY_SYMBOLS=XAUUSD,EURUSD,BTCUSD,USDJPY,NAS100USD,SPX500USD
# AUTO_ENTRY_MIN_SCORE=0.58
# AUTO_ENTRY_MIN_CONFIDENCE=0.50
# AUTO_ENTRY_BREAKOUT_MIN=0.016
# AUTO_ENTRY_PULLBACK_MIN=0.09
# AUTO_ENTRY_PULLBACK_TREND_MIN=0.0009
# RL tabular policy: closed trades (see closed_trades.jsonl). Default = autonomousTag only.
# RL_LEARN_AUTONOMOUS_ONLY=true
# RL_MIN_TRADES_FOR_PROMOTE=8
# RL_MIN_TRADES_FOR_SUSPEND=5

# Dynamic universe manager (rule-based; see docs/DYNAMIC_UNIVERSE_MANAGER.md)
# When true, autonomous engine uses buildDynamicUniverse().activeSymbols (fallback to legacy if build fails).
# DYNAMIC_UNIVERSE_ENABLED=false
# DYNAMIC_UNIVERSE_MAX_ACTIVE=5
# DYNAMIC_UNIVERSE_MAX_WATCHLIST=5
# DYNAMIC_UNIVERSE_BASE_SYMBOLS=XAUUSD,EURUSD,USDJPY,BTCUSD,NAS100USD,SPX500USD
# DYNAMIC_UNIVERSE_EXTRA_SYMBOLS=
# DYNAMIC_UNIVERSE_ALLOW_CRYPTO=true
# DYNAMIC_UNIVERSE_ALLOW_FX=true
# DYNAMIC_UNIVERSE_ALLOW_INDICES=true
# DYNAMIC_UNIVERSE_ALLOW_METALS=true
# DYNAMIC_UNIVERSE_WRITE_SNAPSHOT=true
# DYNAMIC_UNIVERSE_SNAPSHOT_PATH=dynamic_universe_latest.json
# DYNAMIC_UNIVERSE_SUSPENDED_SYMBOLS=

# Phase 2 — macro / news / calendar (see docs/DYNAMIC_UNIVERSE_MACRO.md)
# DYNAMIC_UNIVERSE_MACRO_ENABLED=false
# DYNAMIC_UNIVERSE_NEWS_ENABLED=false
# DYNAMIC_UNIVERSE_CALENDAR_ENABLED=false
# DYNAMIC_UNIVERSE_NEWS_PROVIDER=mock
# DYNAMIC_UNIVERSE_CALENDAR_PROVIDER=mock
# DYNAMIC_UNIVERSE_NEWS_MAX_AGE_MINUTES=360
# DYNAMIC_UNIVERSE_CALENDAR_LOOKAHEAD_HOURS=24
# DYNAMIC_UNIVERSE_MACRO_MAX_BOOST=0.25
# DYNAMIC_UNIVERSE_MACRO_WRITE_SNAPSHOT=true
# DYNAMIC_UNIVERSE_MACRO_SNAPSHOT_PATH=dynamic_universe_macro_latest.json

# Broker / API secrets go below (never log or paste into chat)
