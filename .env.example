# Copy to .env and adjust. Do not commit real .env (secrets).
# Near-live / freshness (aligns with ops/launchd/run-nearlive.sh + com.neuropilot.nearlive.plist)

NEUROPILOT_DATA_ROOT=/Volumes/TradingDrive/NeuroPilotAI

# Bounded critical gate + partial degrade (Yahoo equities not listed — soft / manifest only)
NEUROPILOT_CRITICAL_DATASETS=BTCUSDT_5m,BTCUSDT_1h,ETHUSDT_5m,ETHUSDT_1h,SOLUSDT_5m,SOLUSDT_1h,BNBUSDT_5m,BNBUSDT_1h,ADAUSDT_5m,ADAUSDT_1h,XRPUSDT_5m,XRPUSDT_1h,XAUUSD_5m,XAUUSD_1h
NEUROPILOT_PARTIAL_DEGRADE_ON_STALE=1

# Yahoo equities: visibility only (stale → softMonitorStaleDatasets / run_health, no hard-fail)
NEUROPILOT_SOFT_MONITOR_DATASETS=AAPL_5m,AAPL_1h,IWM_5m,IWM_1h,NVDA_5m,NVDA_1h,QQQ_5m,QQQ_1h,SPY_5m,SPY_1h,TSLA_5m,TSLA_1h

# Paper quality metrics (buildPaperQualityMetrics.js → governance/paper_quality_metrics.json + ops-snapshot/paper_quality_summary.json)
# NEUROPILOT_PAPER_QUALITY_SYMBOLS=ADAUSDT,XRPUSDT
# NEUROPILOT_PAPER_QUALITY_STRATEGIES=ORB_breakout_v1,EMA_pullback_v2
NEUROPILOT_WAVE1_SYMBOLS=BTCUSDT,ETHUSDT,XRPUSDT,ADAUSDT
# NEUROPILOT_WAVE1_FORCE_SIGNALS=1
# Paper signals from generated_strategies/setup_mut_*.json (not meta_ranking):
# NEUROPILOT_WAVE1_FORCE_SIGNALS_FROM_GENERATED=1
# NEUROPILOT_WAVE1_GENERATED_MAX_SETUPS=80
# NEUROPILOT_PAPER_QUALITY_ROLLING_DAYS=7
# (same N for rolling exitTs and rolling simulatedAt)
# NEUROPILOT_PAPER_QUALITY_SINCE_PATCH_AT=2026-03-24T00:00:00.000Z
# governance/paper_quality_actions.json (audit only; never blocks execution)
# NEUROPILOT_PAPER_QUALITY_SUGGEST_MIN_TRADES=4
# NEUROPILOT_PAPER_QUALITY_DEPRIORITIZE_MIN_TRADES=10
# NEUROPILOT_PAPER_QUALITY_DEPRIORITIZE_STRATEGIES=EMA_pullback_v2

# Broker / API secrets go below (never log or paste into chat)
